        "#| echo: false\n",
        "#| fig-cap: \"Rental counts by season (1 = Spring, 2 = Summer, 3 = Autumn, 4 = Winter). Summer and autumn show higher median rentals than spring or winter.\"\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(7, 4))\n",
        "sns.boxplot(data=bikes, x='season', y='cnt', hue='season', legend=False, ax=ax, palette='Set2')\n",
        "ax.set_xlabel('Season (1=Spring, 2=Summer, 3=Autumn, 4=Winter)')\n",
