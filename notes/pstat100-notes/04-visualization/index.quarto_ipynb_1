        "---\n",
        "title: \"Data Visualization\"\n",
        "description: \"Standard visualizations for EDA, matplotlib and seaborn fundamentals, variable-based formatting, and multiplotting with FacetGrid.\"\n",
        "author: \"John Robin Inston\"\n",
        "date: \"2026-05-06\"\n",
        "date-modified: \"2026-05-06\"\n",
        "toc: true\n",
        "title-block-banner: false\n",
